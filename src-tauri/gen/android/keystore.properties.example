# 复制本文件为 keystore.properties（已在 .gitignore），与密钥库放在本目录 gen/android/ 下。
#
# 生成密钥库（在项目根目录或 gen/android 下执行一次）：
#   keytool -genkeypair -v -keystore cloudplayer-release.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# 填写示例（storeFile 相对路径相对于 gen/android/）：
storeFile=cloudplayer-release.jks
storePassword=填写仓库密码
keyAlias=upload
keyPassword=填写别名密码

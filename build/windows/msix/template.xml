<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="cloudplayer"
        Arguments=""
        InstallLocation="C:\Program Files\CloudPlayer">
    </Installer>
    <PackageInformation
        PackageName="CloudPlayer"
        PackageDisplayName="CloudPlayer"
        PublisherName="CN=CloudPlayer"
        PublisherDisplayName="CloudPlayer"
        Version="1.0.0.0"
        PackageDescription="A CloudPlayer application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.cloudplayer.app"
                Description="A CloudPlayer application"
                DisplayName="CloudPlayer"
                ExecutableName="cloudplayer"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>CloudPlayer</DisplayName>
            <PublisherDisplayName>CloudPlayer</PublisherDisplayName>
            <Description>A CloudPlayer application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="cloudplayer.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
